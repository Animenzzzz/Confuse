{
  "file_while_list": ["Services", "Features", "Runner", "Classes"],
  "member_num_min": 3,
  "member_num_max": 8,
  "new_file_count_min": 5,
  "new_file_count_max": 15,
  "call_all_class": "",
  "call_func_name": "invokeObfuscation",
  "hx_folder": "HX",
  "output_subdir": "",
  "inject_properties": true,
  "inject_methods": true,
  "rename_enabled": false,
  "rename_prefix": "Obf",
  "rename_types": true,
  "rename_functions": true,
  "rename_properties": false,
  "skip_line_patterns": [
    "@objc",
    "@IBAction",
    "@IBOutlet",
    "@IBDesignable",
    "@IBInspectable",
    "@main",
    " override ",
    " required init",
    " convenience init",
    " deinit",
    " init(",
    " willSet",
    " didSet",
    " get ",
    " set ",
    "protocol ",
    " associatedtype "
  ],
  "ignore_dirs": ["3rd", "Pods", "Carthage", ".build", "DerivedData", "Flutter", "ephemeral", ".symlinks", "build", ".dart_tool"],
  "ignore_files": ["Package.swift"]
}
