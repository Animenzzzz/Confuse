# 函数重命名 func.sh：遍历工程时跳过的文件夹名
FUNC_IGNORE_FILE=("3rd" "core" "WebView")

# 前缀重命名 projectfile.sh：复制/重命名时跳过的文件或文件夹名
PROJECT_IGNORE_FILE=("Build" "Index" ".gitignore" ".vscode" ".git" "README.md")

# func.sh 临时文件目录（相对 Confuse 仓库根目录）
FUNC_WORK_SUBDIR=".work/default"

# func.sh 宏头文件输出（相对用户输入的工程路径）
OBFUSCATION_SUBDIR="Obfuscation"
OBFUSCATION_HEADER="Qwe_funcObfuscation.h"
OBFUSCATION_HEADER_GUARD="Demo_codeObfuscation_h"
